# ─── Supabase ─────────────────────────────────────────────────────────────────
# Get from: supabase.com → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ─────────────────────────────────────────────────────────────────
# Get from: supabase.com → Settings → Database → Connection string → URI
# Replace [YOUR-PASSWORD] with your actual DB password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get from: razorpay.com → Settings → API Keys → Generate Test Key
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=noreply@petpeep.in

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
ADMIN_EMAIL=admin@petpeep.in
